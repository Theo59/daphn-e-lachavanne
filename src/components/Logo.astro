---
interface Props {
  size?: number;
  mark?: boolean;
  class?: string;
}
const { size = 22, mark = true, class: cls = '' } = Astro.props;
---

<span class={`logo ${cls}`} style={`font-size:${size}px;gap:${size * 0.5}px`}>
  {mark && (
    <img
      src="/media/logo-noir.png"
      alt=""
      aria-hidden="true"
      class="logo-mark"
      style={`height:${size * 1.4}px;width:auto`}
    />
  )}
  <span class="logo-text">
    <span>daphné</span><span class="logo-last">lachavanne</span>
  </span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    line-height: 1;
    color: currentColor;
  }
  .logo-mark {
    display: block;
    filter: brightness(0);
  }
  :global(.nav--hero) .logo-mark {
    filter: brightness(0) invert(1);
  }
  .logo-text {
    display: inline-flex;
    gap: 0.06em;
  }
  .logo-last {
    opacity: 0.7;
  }
</style>

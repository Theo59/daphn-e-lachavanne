---
interface Props {
  size?: number;
  mark?: boolean;
  class?: string;
}
const { size = 22, mark = true, class: cls = '' } = Astro.props;
---

<span class={`logo ${cls}`} style={`font-size:${size}px;gap:${size * 0.5}px`}>
  {mark && (
    <svg width={size * 1.05} height={size * 1.05} viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <ellipse cx="16" cy="16" rx="14" ry="9" stroke="currentColor" stroke-width="1" />
      <circle cx="16" cy="16" r="2.5" fill="currentColor" />
    </svg>
  )}
  <span class="logo-text">
    <span>daphné</span><span class="logo-last">lachavanne</span>
  </span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    line-height: 1;
    color: currentColor;
  }
  .logo-text {
    display: inline-flex;
    gap: 0.06em;
  }
  .logo-last {
    opacity: 0.7;
  }
</style>

---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  activePage?: string;
  darkNav?: boolean;
  noFooter?: boolean;
}

const {
  title = 'Daphné Lachavanne — Yoga · Breathwork · Pilates · Soins',
  description = 'Praticienne en yoga, breathwork, pilates et soins à Genève. Au Loft.',
  activePage = 'home',
  darkNav = false,
  noFooter = false,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Tenor+Sans&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
</head>
<body>
  <Nav active={activePage} dark={darkNav} />
  <main>
    <slot />
  </main>
  {!noFooter && <Footer />}
  <script>
    import '../scripts/animations.ts';
  </script>
</body>
</html>
